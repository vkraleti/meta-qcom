+++ b/arch/arm64/boot/dts/qcom/iq10-rrd.dts
@@ -564,6 +564,34 @@ &remoteproc_adsp {
 	status = "okay";
 };
 
+&remoteproc_cdsp0 {
+	firmware-name = "qcom/nord/cdsp.mbn",
+			"qcom/nord/cdsp_dtbs.elf";
+
+	status = "okay";
+};
+
+&remoteproc_cdsp1 {

From 63720c6b6402eb937728abbb88b12921e00a4d54 Mon Sep 17 00:00:00 2001
From: Shawn Guo <shengchao.guo@oss.qualcomm.com>
Date: Thu, 14 May 2026 14:24:10 +0800
Subject: [PATCH 1/6] arm64: dts: qcom: nord: Add support for ADSP

Add device tree nodes to support ADSP (HPASS DSP) remoteproc on Nord SoC.

This includes:
- SMEM memory reservation used by the inter-processor communication
  infrastructure
- IPCC mailbox controller for inter-processor signalling
- AOSS QMP node for load state power management
- SMP2P nodes providing stop control and fault/crash interrupt signals
- Remoteproc nodes for ADSP (@4c00000) with a GLINK edge and FastRPC
  compute contexts for userspace offload

The embedded variant specific power domains (CX/MX), XO clock, and HPASS
interconnect paths are filled in nord-embedded.dtsi.

Signed-off-by: Shawn Guo <shengchao.guo@oss.qualcomm.com>
Upstream-Status: Pending
---
 arch/arm64/boot/dts/qcom/nord-embedded.dtsi |  11 ++
 arch/arm64/boot/dts/qcom/nord-ipcc.h        | 163 ++++++++++++++++++++
 arch/arm64/boot/dts/qcom/nord.dtsi          | 142 +++++++++++++++++
 3 files changed, 316 insertions(+)
 create mode 100644 arch/arm64/boot/dts/qcom/nord-ipcc.h

diff --git a/arch/arm64/boot/dts/qcom/nord-embedded.dtsi b/arch/arm64/boot/dts/qcom/nord-embedded.dtsi
index 619025011b569..72f6c0fccab8f 100644
--- a/arch/arm64/boot/dts/qcom/nord-embedded.dtsi
+++ b/arch/arm64/boot/dts/qcom/nord-embedded.dtsi
@@ -559,6 +559,17 @@ &config_noc SLAVE_QUP_2 QCOM_ICC_TAG_ALWAYS>,
 	pinctrl-names = "default";
 };
 
+&remoteproc_adsp {
+	clocks = <&rpmhcc RPMH_CXO_CLK>;
+	clock-names = "xo";
+	interconnects = <&hpass_ag_noc MASTER_HPASS_PROC_0 QCOM_ICC_TAG_ALWAYS
+			 &mc_virt SLAVE_EBI1 QCOM_ICC_TAG_ALWAYS>;
+	power-domains = <&rpmhpd RPMHPD_CX>,
+			<&rpmhpd RPMHPD_MX>;
+	power-domain-names = "cx",
+			     "mx";
+};
+
 &soc {
 	gcc: clock-controller@100000 {
 		compatible = "qcom,nord-gcc";
